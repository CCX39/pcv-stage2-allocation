{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CCX39/pcv-stage2-allocation/schemas/stage2_result.schema.json",
  "title": "Stage2 MVP Result",
  "description": "Schema for the current Stage2 structured solver output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "status",
    "budget_total_bytes",
    "b_min_feasible",
    "budget_gap",
    "total_bytes",
    "total_net_utility",
    "total_spatial_utility",
    "total_decode_ms",
    "budget_utilization",
    "selected_tiles",
    "lookup_resolution",
    "lambda_search",
    "local_upgrade",
    "runtime_ms",
    "config_snapshot",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "INFEASIBLE_BUDGET",
        "INVALID_INPUT",
        "INVALID_LOOKUP",
        "NO_ALLOWED_LEVEL",
        "NUMERICAL_ERROR",
        "INTERNAL_CONSTRAINT_VIOLATION"
      ]
    },
    "budget_total_bytes": {
      "type": "number",
      "minimum": 0
    },
    "b_min_feasible": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "budget_gap": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_bytes": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "total_net_utility": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_spatial_utility": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_decode_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "budget_utilization": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "selected_tiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selectedTile"
      }
    },
    "lookup_resolution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lookupResolution"
      }
    },
    "lambda_search": {
      "$ref": "#/$defs/lambdaSearch"
    },
    "local_upgrade": {
      "$ref": "#/$defs/localUpgrade"
    },
    "runtime_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "config_snapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    }
  },
  "$defs": {
    "selectedTile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "selected_level_id",
        "r_bytes",
        "d_ms",
        "net_utility",
        "spatial_utility",
        "allowed_levels"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_level_id": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "r_bytes": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "d_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "net_utility": {
          "type": [
            "number",
            "null"
          ]
        },
        "spatial_utility": {
          "type": [
            "number",
            "null"
          ]
        },
        "allowed_levels": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "lookupResolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "lookup_profile_id",
        "lookup_level",
        "allowed_levels"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "lookup_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "matched_rule_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "lookup_level": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "allowed_levels": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "lambdaSearch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "lambda_initial_high",
        "lambda_max_bracket_steps",
        "score_epsilon",
        "lambda_epsilon",
        "max_iterations",
        "iterations",
        "best_feasible_iteration"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "lambda_initial_high": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0
        },
        "lambda_max_bracket_steps": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "score_epsilon": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "lambda_epsilon": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "max_iterations": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "iterations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lambdaIteration"
          }
        },
        "best_feasible_iteration": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "lambdaIteration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iteration",
        "lambda",
        "total_bytes",
        "total_net_utility",
        "total_decode_ms",
        "selected_levels",
        "is_budget_feasible"
      ],
      "properties": {
        "iteration": {
          "type": "integer",
          "minimum": 0
        },
        "lambda": {
          "type": "number",
          "minimum": 0
        },
        "total_bytes": {
          "type": "number",
          "minimum": 0
        },
        "total_net_utility": {
          "type": "number"
        },
        "total_decode_ms": {
          "type": "number",
          "minimum": 0
        },
        "selected_levels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lambdaSelectedLevel"
          }
        },
        "is_budget_feasible": {
          "type": "boolean"
        }
      }
    },
    "lambdaSelectedLevel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "selected_level_id"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_level_id": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "localUpgrade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "seed_best_feasible_trace_index",
        "initial_total_bytes",
        "initial_total_net_utility",
        "initial_total_decode_ms",
        "steps",
        "termination_reason"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "seed_best_feasible_trace_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "initial_total_bytes": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "initial_total_net_utility": {
          "type": [
            "number",
            "null"
          ]
        },
        "initial_total_decode_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localUpgradeStep"
          }
        },
        "termination_reason": {
          "type": "string",
          "enum": [
            "NOT_RUN",
            "NO_FEASIBLE_POSITIVE_UPGRADE"
          ]
        }
      }
    },
    "localUpgradeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_index",
        "tile_id",
        "from_level_id",
        "to_level_id",
        "delta_r_bytes",
        "delta_net_utility",
        "gain_per_byte",
        "total_bytes_after",
        "total_net_utility_after",
        "total_decode_ms_after"
      ],
      "properties": {
        "step_index": {
          "type": "integer",
          "minimum": 0
        },
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "from_level_id": {
          "type": "integer",
          "minimum": 1
        },
        "to_level_id": {
          "type": "integer",
          "minimum": 1
        },
        "delta_r_bytes": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "delta_net_utility": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "gain_per_byte": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "total_bytes_after": {
          "type": "number",
          "minimum": 0
        },
        "total_net_utility_after": {
          "type": "number"
        },
        "total_decode_ms_after": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
