{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcv-stage2.local/schemas/stage2_result.schema.json",
  "title": "Stage2SolveResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "status",
    "budget_total_bytes",
    "b_min_feasible",
    "budget_gap",
    "total_bytes",
    "total_net_utility",
    "total_spatial_utility",
    "total_decode_ms",
    "budget_utilization",
    "selected_tiles",
    "lookup_resolution",
    "lambda_search",
    "local_upgrade",
    "runtime_ms",
    "config_snapshot",
    "warnings",
    "errors"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "INFEASIBLE_BUDGET",
        "INVALID_INPUT",
        "INVALID_LOOKUP",
        "NO_ALLOWED_CANDIDATE",
        "NUMERICAL_ERROR",
        "INTERNAL_CONSTRAINT_VIOLATION"
      ]
    },
    "budget_total_bytes": {
      "type": "number",
      "minimum": 0
    },
    "b_min_feasible": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "budget_gap": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_bytes": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "total_net_utility": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_spatial_utility": {
      "type": [
        "number",
        "null"
      ]
    },
    "total_decode_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "budget_utilization": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "selected_tiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/selected_tile"
      }
    },
    "lookup_resolution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lookup_resolution"
      }
    },
    "lambda_search": {
      "$ref": "#/$defs/lambda_search"
    },
    "local_upgrade": {
      "$ref": "#/$defs/local_upgrade"
    },
    "runtime_ms": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "config_snapshot": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/message"
      }
    }
  },
  "$defs": {
    "provenance_value": {
      "type": "string",
      "enum": [
        "measured",
        "calibrated",
        "derived",
        "proxy",
        "synthetic"
      ]
    },
    "provenance_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/provenance_value"
      }
    },
    "candidate_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "pdl_ratio",
        "file_format",
        "codec",
        "codec_params",
        "asset_ref",
        "r_bytes",
        "d_ms",
        "q_base",
        "provenance"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "pdl_ratio": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "file_format": {
          "type": "string",
          "minLength": 1
        },
        "codec": {
          "type": "string",
          "minLength": 1
        },
        "codec_params": {
          "type": "object"
        },
        "asset_ref": {
          "type": "string",
          "minLength": 1
        },
        "r_bytes": {
          "type": "number",
          "minimum": 0
        },
        "d_ms": {
          "type": "number",
          "minimum": 0
        },
        "q_base": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "allOf": [
            {
              "$ref": "#/$defs/provenance_map"
            },
            {
              "required": [
                "r_bytes",
                "d_ms",
                "q_base",
                "pdl_ratio",
                "asset_ref"
              ]
            }
          ]
        }
      }
    },
    "selected_tile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "selected_candidate_id",
        "selected_candidate_snapshot",
        "r_bytes",
        "d_ms",
        "net_utility",
        "spatial_utility",
        "allowed_candidate_ids",
        "rejected_candidate_ids",
        "lookup_pdl_max_dist"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_candidate_snapshot": {
          "$ref": "#/$defs/candidate_snapshot"
        },
        "r_bytes": {
          "type": "number",
          "minimum": 0
        },
        "d_ms": {
          "type": "number",
          "minimum": 0
        },
        "net_utility": {
          "type": "number"
        },
        "spatial_utility": {
          "type": "number"
        },
        "allowed_candidate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rejected_candidate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "lookup_pdl_max_dist": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "lookup_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "lookup_profile_id",
        "matched_rule_id",
        "pdl_max_dist",
        "allowed_candidate_ids",
        "rejected_candidate_ids"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "lookup_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "matched_rule_id": {
          "type": "string",
          "minLength": 1
        },
        "pdl_max_dist": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "allowed_candidate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rejected_candidate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "lambda_search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "lambda_initial_high",
        "lambda_max_bracket_steps",
        "score_epsilon",
        "lambda_epsilon",
        "max_iterations",
        "iterations",
        "best_feasible_iteration"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "lambda_initial_high": {
          "type": [
            "number",
            "null"
          ]
        },
        "lambda_max_bracket_steps": {
          "type": [
            "integer",
            "null"
          ]
        },
        "score_epsilon": {
          "type": [
            "number",
            "null"
          ]
        },
        "lambda_epsilon": {
          "type": [
            "number",
            "null"
          ]
        },
        "max_iterations": {
          "type": [
            "integer",
            "null"
          ]
        },
        "iterations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lambda_iteration"
          }
        },
        "best_feasible_iteration": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "lambda_iteration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "iteration",
        "lambda",
        "total_bytes",
        "total_net_utility",
        "total_decode_ms",
        "selected_candidates",
        "is_budget_feasible"
      ],
      "properties": {
        "iteration": {
          "type": "integer",
          "minimum": 0
        },
        "lambda": {
          "type": "number",
          "minimum": 0
        },
        "total_bytes": {
          "type": "number",
          "minimum": 0
        },
        "total_net_utility": {
          "type": "number"
        },
        "total_decode_ms": {
          "type": "number",
          "minimum": 0
        },
        "selected_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lambda_selected_candidate"
          }
        },
        "is_budget_feasible": {
          "type": "boolean"
        }
      }
    },
    "lambda_selected_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "selected_candidate_id"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "selected_candidate_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "local_upgrade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "seed_best_feasible_trace_index",
        "initial_total_bytes",
        "initial_total_net_utility",
        "initial_total_decode_ms",
        "steps",
        "termination_reason"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "seed_best_feasible_trace_index": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "initial_total_bytes": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "initial_total_net_utility": {
          "type": [
            "number",
            "null"
          ]
        },
        "initial_total_decode_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/local_upgrade_step"
          }
        },
        "termination_reason": {
          "type": "string"
        }
      }
    },
    "local_upgrade_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_index",
        "tile_id",
        "from_candidate_id",
        "to_candidate_id",
        "delta_r_bytes",
        "delta_net_utility",
        "gain_per_byte",
        "residual_budget_before",
        "residual_budget_after",
        "total_bytes_after",
        "total_net_utility_after",
        "total_decode_ms_after",
        "selection_reason"
      ],
      "properties": {
        "step_index": {
          "type": "integer",
          "minimum": 0
        },
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "from_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "to_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "delta_r_bytes": {
          "type": "number"
        },
        "delta_net_utility": {
          "type": "number"
        },
        "gain_per_byte": {
          "type": "number"
        },
        "residual_budget_before": {
          "type": "number",
          "minimum": 0
        },
        "residual_budget_after": {
          "type": "number",
          "minimum": 0
        },
        "total_bytes_after": {
          "type": "number",
          "minimum": 0
        },
        "total_net_utility_after": {
          "type": "number"
        },
        "total_decode_ms_after": {
          "type": "number",
          "minimum": 0
        },
        "selection_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
