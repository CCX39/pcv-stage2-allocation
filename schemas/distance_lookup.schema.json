{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcv-stage2.local/schemas/distance_lookup.schema.json",
  "title": "DistanceLookup",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lookup_profile_id",
    "semantics",
    "distance_unit",
    "pdl_support",
    "source",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "lookup_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "semantics": {
      "type": "string",
      "const": "cap"
    },
    "distance_unit": {
      "type": "string",
      "minLength": 1
    },
    "pdl_support": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pdl_support_item"
      }
    },
    "source": {
      "type": "object"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "pdl_support_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdl_ratio",
        "quality_label"
      ],
      "properties": {
        "pdl_ratio": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "quality_label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "distance_match": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "exact_distance"
          ],
          "properties": {
            "exact_distance": {
              "type": "number"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "distance_min",
            "distance_max"
          ],
          "properties": {
            "distance_min": {
              "type": "number"
            },
            "distance_max": {
              "type": "number"
            }
          }
        }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "view_context",
        "target_id",
        "distance_match",
        "pdl_max_dist",
        "threshold_profile"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1
        },
        "view_context": {
          "type": "string",
          "minLength": 1
        },
        "target_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "distance_match": {
          "$ref": "#/$defs/distance_match"
        },
        "pdl_max_dist": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "threshold_profile": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
