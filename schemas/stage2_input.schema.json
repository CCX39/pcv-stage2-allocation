{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcv-stage2.local/schemas/stage2_input.schema.json",
  "title": "Stage2Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "budget_total_bytes",
    "eta",
    "lookup_profile_id",
    "tiles",
    "provenance_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "budget_total_bytes": {
      "type": "number",
      "minimum": 0
    },
    "eta": {
      "type": "number",
      "minimum": 0
    },
    "lookup_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tile"
      }
    },
    "provenance_summary": {
      "type": "object"
    }
  },
  "$defs": {
    "provenance_value": {
      "type": "string",
      "enum": [
        "measured",
        "calibrated",
        "derived",
        "proxy",
        "synthetic"
      ]
    },
    "provenance_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/provenance_value"
      }
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tile_id",
        "p_sal",
        "visibility",
        "screen_area",
        "distance_norm",
        "view_context",
        "candidates"
      ],
      "properties": {
        "tile_id": {
          "type": "string",
          "minLength": 1
        },
        "p_sal": {
          "type": "number",
          "minimum": 0
        },
        "visibility": {
          "type": "number",
          "minimum": 0
        },
        "screen_area": {
          "type": "number",
          "minimum": 0
        },
        "distance_norm": {
          "type": "number"
        },
        "view_context": {
          "type": "string",
          "minLength": 1
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/candidate"
          }
        },
        "provenance": {
          "$ref": "#/$defs/provenance_map"
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "file_format",
        "codec",
        "codec_params",
        "asset_ref",
        "r_bytes",
        "d_ms",
        "q_base",
        "provenance"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "pdl_ratio": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "file_format": {
          "type": "string",
          "minLength": 1
        },
        "codec": {
          "type": "string",
          "minLength": 1
        },
        "codec_params": {
          "type": "object"
        },
        "asset_ref": {
          "type": "string",
          "minLength": 1
        },
        "r_bytes": {
          "type": "number",
          "minimum": 0
        },
        "d_ms": {
          "type": "number",
          "minimum": 0
        },
        "q_base": {
          "type": "number",
          "minimum": 0
        },
        "provenance": {
          "allOf": [
            {
              "$ref": "#/$defs/provenance_map"
            },
            {
              "required": [
                "r_bytes",
                "d_ms",
                "q_base",
                "pdl_ratio",
                "asset_ref"
              ]
            }
          ]
        }
      }
    }
  }
}
